# TTGO Chat Controller Bridge — environment variables
# Copy to .env (or add to ~/.hermes/.env) and fill in real values.

# ── Hermes API server (OpenAI-compatible) ───────────────────────────────────
# HERMES_API_KEY must match API_SERVER_KEY in ~/.hermes/config.yaml.
HERMES_API_KEY=
HERMES_API_BASE=http://localhost:8642
HERMES_API_MODEL=hermes-agent

# ── STT: Groq Whisper (free tier) ───────────────────────────────────────────
# Get one at https://console.groq.com/keys
GROQ_API_KEY=

# ── Serial ──────────────────────────────────────────────────────────────────
TTGO_CHAT_PORT=/dev/ttyACM0
TTGO_CHAT_BAUD=115200

# ── Audio ───────────────────────────────────────────────────────────────────
# Microphone (ALSA). Find yours with: arecord -l
# Examples: hw:1,0 (USB mic), hw:3,0 (C920 webcam), default
TTGO_MIC_DEVICE=hw:1,0

# Speaker output. Examples:
#   plughw:0,0                                         → 3.5mm jack / HDMI
#   default                                            → ALSA default
#   bluealsa:DEV=AA:BB:CC:DD:EE:FF,PROFILE=a2dp        → Bluetooth A2DP speaker
TTGO_BT_DEVICE=default

# ── TTS (edge-tts — free, no API key) ───────────────────────────────────────
# Browse voices: `edge-tts --list-voices`
TTGO_TTS_VOICE=en-US-AvaMultilingualNeural

# ── Display ─────────────────────────────────────────────────────────────────
# Context window size for the % bar. Match your model (Claude/DeepSeek ~200k, GPT-4o ~128k, etc.)
CTX_WINDOW_TOKENS=200000
